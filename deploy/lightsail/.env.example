PIPE1_LICENSE_DOMAIN=license.example.com
PIPE1_DOWNLOADS_DIR=/opt/pipe1-downloads
PIPE1_LICENSE_SIGNING_PRIVATE_KEY=
PIPE1_SIGNING_KEY_ID=license-signing-key-001
PIPE1_ADMIN_USERNAME=admin
PIPE1_ADMIN_PASSWORD_HASH=
PIPE1_ADMIN_SESSION_SECRET=
# Optional TOTP MFA secret. Use base32 without spaces.
PIPE1_ADMIN_TOTP_SECRET=
# Space-separated CIDR list. Defaults to localhost only when unset.
PIPE1_ADMIN_ALLOWED_IPS=127.0.0.1/32 ::1/128
PIPE1_ADMIN_LOGIN_RATE_LIMIT_ATTEMPTS=5
PIPE1_ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
POSTGRES_DB=pipe1_license
POSTGRES_USER=pipe1
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+psycopg://pipe1:change-this-password@db:5432/pipe1_license
